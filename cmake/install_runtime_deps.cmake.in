if(POLICY CMP0207)
    cmake_policy(SET CMP0207 NEW)
endif()
if(POLICY CMP0057)
    cmake_policy(SET CMP0057 NEW)
endif()

set(_gis_ai_install_bin_dir "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@")
set(_gis_ai_install_platform_dir "${CMAKE_INSTALL_PREFIX}/@GIS_AI_INSTALL_PLATFORM_DIR@")
set(_gis_ai_install_sqldrivers_dir "${CMAKE_INSTALL_PREFIX}/@GIS_AI_INSTALL_SQLDRIVERS_DIR@")

set(_gis_ai_runtime_executables
    "${_gis_ai_install_bin_dir}/gis_ai_cli.exe"
)

if(EXISTS "${_gis_ai_install_bin_dir}/gis-ai-gui.exe")
    list(APPEND _gis_ai_runtime_executables "${_gis_ai_install_bin_dir}/gis-ai-gui.exe")
endif()

set(_gis_ai_runtime_libraries)

if(EXISTS "${_gis_ai_install_bin_dir}/gis_ai.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_bin_dir}/gis_ai.dll")
endif()

if(EXISTS "${_gis_ai_install_platform_dir}/qwindows.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_platform_dir}/qwindows.dll")
endif()

if(EXISTS "${_gis_ai_install_platform_dir}/qwindowsd.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_platform_dir}/qwindowsd.dll")
endif()

if(EXISTS "${_gis_ai_install_platform_dir}/qoffscreen.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_platform_dir}/qoffscreen.dll")
endif()

if(EXISTS "${_gis_ai_install_platform_dir}/qoffscreend.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_platform_dir}/qoffscreend.dll")
endif()

if(EXISTS "${_gis_ai_install_sqldrivers_dir}/qsqlite.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_sqldrivers_dir}/qsqlite.dll")
endif()

if(EXISTS "${_gis_ai_install_sqldrivers_dir}/qsqlited.dll")
    list(APPEND _gis_ai_runtime_libraries "${_gis_ai_install_sqldrivers_dir}/qsqlited.dll")
endif()

set(_gis_ai_can_scan_runtime_deps TRUE)

if(WIN32)
    function(_gis_ai_try_configure_dumpbin_from_vswhere)
        if(NOT DEFINED ENV{ProgramFiles\(x86\)})
            return()
        endif()

        set(_gis_ai_program_files_x86 "$ENV{ProgramFiles\(x86\)}")
        set(_gis_ai_vswhere "${_gis_ai_program_files_x86}/Microsoft Visual Studio/Installer/vswhere.exe")
        if(NOT EXISTS "${_gis_ai_vswhere}")
            return()
        endif()

        execute_process(
            COMMAND "${_gis_ai_vswhere}"
                -latest
                -products *
                -requires Microsoft.VisualStudio.Component.VC.Tools.x86.x64
                -property installationPath
            OUTPUT_VARIABLE _gis_ai_vs_install_path
            RESULT_VARIABLE _gis_ai_vswhere_result
            OUTPUT_STRIP_TRAILING_WHITESPACE
        )

        if(NOT _gis_ai_vswhere_result EQUAL 0 OR _gis_ai_vs_install_path STREQUAL "")
            return()
        endif()

        file(GLOB _gis_ai_dumpbin_candidates
            "${_gis_ai_vs_install_path}/VC/Tools/MSVC/*/bin/Hostx64/x64/dumpbin.exe"
        )
        list(SORT _gis_ai_dumpbin_candidates ORDER DESCENDING)
        list(GET _gis_ai_dumpbin_candidates 0 _gis_ai_dumpbin_candidate)

        if(EXISTS "${_gis_ai_dumpbin_candidate}")
            set(_gis_ai_dumpbin_command "${_gis_ai_dumpbin_candidate}" PARENT_SCOPE)
        endif()
    endfunction()

    find_program(_gis_ai_dumpbin_command dumpbin)
    find_program(_gis_ai_llvm_objdump_command llvm-objdump)
    find_program(_gis_ai_objdump_command objdump)

    if(NOT _gis_ai_dumpbin_command)
        _gis_ai_try_configure_dumpbin_from_vswhere()
    endif()

    if(_gis_ai_dumpbin_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL dumpbin)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_ai_dumpbin_command}")
    elseif(_gis_ai_llvm_objdump_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL objdump)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_ai_llvm_objdump_command}")
    elseif(_gis_ai_objdump_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL objdump)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_ai_objdump_command}")
    else()
        set(_gis_ai_can_scan_runtime_deps FALSE)
        message(WARNING "未找到 dumpbin/objdump 工具，回退到直接复制最小运行时 DLL 列表。")
    endif()
endif()

set(_gis_ai_vcpkg_bin_dir "@GIS_AI_VCPKG_RELEASE_BIN_DIR@")
if(EXISTS "${_gis_ai_install_platform_dir}/qwindowsd.dll")
    set(_gis_ai_vcpkg_bin_dir "@GIS_AI_VCPKG_DEBUG_BIN_DIR@")
endif()

if(_gis_ai_can_scan_runtime_deps)
    file(GET_RUNTIME_DEPENDENCIES
        EXECUTABLES ${_gis_ai_runtime_executables}
        LIBRARIES ${_gis_ai_runtime_libraries}
        RESOLVED_DEPENDENCIES_VAR _gis_ai_resolved_deps
        UNRESOLVED_DEPENDENCIES_VAR _gis_ai_unresolved_deps
        DIRECTORIES
            "${_gis_ai_vcpkg_bin_dir}"
        PRE_EXCLUDE_REGEXES
            "api-ms-"
            "ext-ms-"
            "[Hh][Vv][Ss][Ii][Ff]ile[Tt]rust\\.dll"
        POST_EXCLUDE_REGEXES
            ".*/install/bin/.*"
            ".*/[Ww]indows/.*"
            ".*/[Ss]ystem32/.*"
    )

    if(_gis_ai_unresolved_deps)
        list(JOIN _gis_ai_unresolved_deps "\n  " _gis_ai_unresolved_text)
        message(WARNING "未解析的运行时依赖（可能需要手动安装）:\n  ${_gis_ai_unresolved_text}")
    endif()

    set(_gis_ai_filtered_resolved_deps)
    foreach(_gis_ai_dep IN LISTS _gis_ai_resolved_deps)
        get_filename_component(_gis_ai_dep_dir "${_gis_ai_dep}" DIRECTORY)
        file(TO_CMAKE_PATH "${_gis_ai_dep_dir}" _gis_ai_dep_dir_norm)
        file(TO_CMAKE_PATH "${_gis_ai_install_bin_dir}" _gis_ai_install_bin_dir_norm)
        if(_gis_ai_dep_dir_norm STREQUAL _gis_ai_install_bin_dir_norm)
            continue()
        endif()
        list(APPEND _gis_ai_filtered_resolved_deps "${_gis_ai_dep}")
    endforeach()

    list(REMOVE_DUPLICATES _gis_ai_filtered_resolved_deps)

    message(STATUS "已解析的运行时依赖: ${_gis_ai_filtered_resolved_deps}")

    if(NOT _gis_ai_filtered_resolved_deps)
        set(_gis_ai_can_scan_runtime_deps FALSE)
        message(WARNING "GET_RUNTIME_DEPENDENCIES 未发现依赖，回退到最小 DLL 列表。")
    endif()
endif()

if(_gis_ai_can_scan_runtime_deps)
    foreach(_gis_ai_dep IN LISTS _gis_ai_filtered_resolved_deps)
        file(INSTALL
            DESTINATION "${_gis_ai_install_bin_dir}"
            TYPE SHARED_LIBRARY
            FILES "${_gis_ai_dep}"
        )
    endforeach()
else()
    set(_gis_ai_minimal_dlls
        @GIS_AI_RUNTIME_DLLS_INSTALL_ENTRIES@
        Qt6Core.dll
        Qt6Gui.dll
        Qt6Sql.dll
        Qt6Svg.dll
        Qt6Widgets.dll
    )

    set(_gis_ai_fallback_bin_dir "@GIS_AI_VCPKG_RELEASE_BIN_DIR@")
    if(_gis_ai_vcpkg_bin_dir STREQUAL "@GIS_AI_VCPKG_DEBUG_BIN_DIR@")
        set(_gis_ai_fallback_bin_dir "@GIS_AI_VCPKG_DEBUG_BIN_DIR@")
        set(_gis_ai_minimal_dlls
            @GIS_AI_RUNTIME_DLLS_INSTALL_ENTRIES@
            Qt6Cored.dll
            Qt6Guid.dll
            Qt6Sqld.dll
            Qt6Svgd.dll
            Qt6Widgetsd.dll
        )
    endif()

    foreach(_gis_ai_dll_name IN LISTS _gis_ai_minimal_dlls)
        set(_gis_ai_dll_path "${_gis_ai_fallback_bin_dir}/${_gis_ai_dll_name}")
        if(EXISTS "${_gis_ai_dll_path}")
            file(INSTALL
                DESTINATION "${_gis_ai_install_bin_dir}"
                TYPE SHARED_LIBRARY
                FILES "${_gis_ai_dll_path}"
            )
        endif()
    endforeach()
endif()

foreach(_gis_ai_qt_dir IN ITEMS "${_gis_ai_install_platform_dir}" "${_gis_ai_install_sqldrivers_dir}")
    if(NOT EXISTS "${_gis_ai_qt_dir}")
        file(MAKE_DIRECTORY "${_gis_ai_qt_dir}")
    endif()
endforeach()
