# GIS AI Library Development Environment
# Multi-stage build for consistent development across platforms

FROM ubuntu:22.04 as base

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    # Build tools
    build-essential \
    cmake \
    ninja-build \
    git \
    wget \
    curl \
    # Compiler
    g++-11 \
    gcc-11 \
    # GIS libraries
    libgdal-dev \
    libgeos-dev \
    libproj-dev \
    proj-bin \
    # AI/ML libraries
    libonnxruntime-dev \
    # Utility libraries
    libspdlog-dev \
    libgtest-dev \
    # Additional tools
    python3 \
    python3-pip \
    ca-certificates \
    # Cleanup
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Set compiler alternatives
RUN update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-11 100 \
    && update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-11 100

# Install vcpkg
RUN git clone https://github.com/Microsoft/vcpkg.git /opt/vcpkg && \
    cd /opt/vcpkg && \
    ./bootstrap-vcpkg.sh && \
    ./vcpkg integrate install

ENV VCPKG_ROOT=/opt/vcpkg
ENV PATH="/opt/vcpkg:${PATH}"

# Set working directory
WORKDIR /workspace

# Default command
CMD ["/bin/bash"]

# Development image with all tools pre-configured
FROM base as dev

# Install additional development tools
RUN apt-get update && apt-get install -y \
    clang-format \
    cppcheck \
    valgrind \
    gdb \
    && rm -rf /var/lib/apt/lists/*

# Configure git (optional, for containerized development)
RUN git config --global --add safe.directory /workspace

# Create a non-root user for development
RUN useradd -m -s /bin/bash developer && \
    chown -R developer:developer /workspace

USER developer

# Set up working directory for developer user
WORKDIR /home/developer/workspace

CMD ["/bin/bash"]
