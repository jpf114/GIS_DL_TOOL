#include <windows.h>

1 ICON "@CMAKE_SOURCE_DIR@/resources/app.ico"

1 VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404b0"
        BEGIN
            VALUE "CompanyName", "GIS_AI"
            VALUE "FileDescription", "GIS AI TOOLKIT - Remote Sensing Intelligent Processing"
            VALUE "FileVersion", "@PROJECT_VERSION@"
            VALUE "InternalName", "gis-ai-gui"
            VALUE "LegalCopyright", "Copyright (C) 2026 GIS_AI. MIT License"
            VALUE "OriginalFilename", "gis-ai-gui.exe"
            VALUE "ProductName", "GIS AI TOOLKIT"
            VALUE "ProductVersion", "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200
    END
END
